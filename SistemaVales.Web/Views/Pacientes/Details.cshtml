@model SistemaVales.Models.Paciente

@{
    ViewData["Title"] = "Detalles del Paciente";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1"><i class="bi bi-person-lines-fill text-info me-2"></i> Detalles de Paciente</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Ficha técnica y datos de contacto</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="Index" class="btn btn-sm btn-light-primary btn-active-light-primary me-2">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning text-white">
                <i class="bi bi-pencil"></i> Editar
            </a>
        </div>
    </div>
    <div class="card-body py-9">
        <div class="row align-items-center mb-7">
            <div class="col-sm-4">
                <div class="text-muted fw-semibold fs-6">Nombre Completo</div>
            </div>
            <div class="col-sm-8">
                <div class="fw-bold fs-5 text-dark">@Model.Nombre</div>
            </div>
        </div>

        <div class="row align-items-center mb-7">
            <div class="col-sm-4">
                <div class="text-muted fw-semibold fs-6">DNI</div>
            </div>
            <div class="col-sm-8">
                <div class="fw-bold fs-5 text-dark">@Model.DNI</div>
            </div>
        </div>

        <div class="row align-items-center mb-7">
            <div class="col-sm-4">
                <div class="text-muted fw-semibold fs-6">Dirección</div>
            </div>
            <div class="col-sm-8">
                <div class="fw-bold fs-5 text-dark">@Model.Direccion</div>
            </div>
        </div>

        <div class="row align-items-center mb-7">
            <div class="col-sm-4">
                <div class="text-muted fw-semibold fs-6">Teléfono</div>
            </div>
            <div class="col-sm-8">
                <div class="fw-bold fs-5 text-dark">@Model.Telefono</div>
            </div>
        </div>

        <div class="row align-items-center mb-7">
            <div class="col-sm-4">
                <div class="text-muted fw-semibold fs-6">Hospital de Atención</div>
            </div>
            <div class="col-sm-8">
                <span class="badge badge-light-success fs-6 fw-bold">@(Model.Hospital?.Nombre ?? "Sin asignar")</span>
            </div>
        </div>
    </div>
</div>
