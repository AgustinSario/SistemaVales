@model SistemaVales.Models.Expediente

@{
    ViewData["Title"] = "Detalles del Expediente";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1"><i class="bi bi-folder2-open text-primary me-2"></i> Expediente #@Model.NumeroExpediente</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Estado actual e historial de documentación</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="Index" class="btn btn-sm btn-light-primary btn-active-light-primary me-2">
                <i class="bi bi-arrow-left"></i> Volver al listado
            </a>
        </div>
    </div>
    <div class="card-body py-9">
        <div class="row mb-10">
            <div class="col-lg-6">
                <!-- Info Section -->
                <h5 class="fw-bold mb-4 text-dark">Información General</h5>
                
                <div class="row mb-5">
                    <div class="col-sm-5 text-muted fw-semibold fs-6">Fecha Inicio</div>
                    <div class="col-sm-7 fw-bold fs-6 text-dark">@Model.FechaInicio.ToShortDateString()</div>
                </div>
                
                <div class="row mb-5">
                    <div class="col-sm-5 text-muted fw-semibold fs-6">Estado Actual</div>
                    <div class="col-sm-7">
                        @if(Model.Estado == "Favorable") {
                            <span class="badge badge-light-success fs-6 fw-bold p-2"><i class="bi bi-check text-success fs-5 me-1"></i> Favorable</span>
                        } else {
                            <span class="badge badge-light-warning fs-6 fw-bold p-2">@Model.Estado</span>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <!-- Checklist Section -->
                <div class="border border-dashed border-gray-300 rounded p-6 bg-light">
                    <h5 class="fw-bold mb-4 text-dark">Checklist de Documentación</h5>
                    
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center">
                            @if(Model.InformeSocialEconomico) {
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <span class="fw-bold text-dark fs-6 d-block">Informe Socio-Económico Presentado</span>
                            } else {
                                <i class="bi bi-x-circle-fill text-danger fs-4 me-3"></i>
                                <span class="fw-semibold text-muted fs-6 text-decoration-line-through">Informe Socio-Económico</span>
                            }
                        </div>
                        
                        <div class="d-flex align-items-center">
                            @if(Model.HistoriaClinica) {
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <span class="fw-bold text-dark fs-6 d-block">Historia Clínica Validada</span>
                            } else {
                                <i class="bi bi-x-circle-fill text-danger fs-4 me-3"></i>
                                <span class="fw-semibold text-muted fs-6 text-decoration-line-through">Historia Clínica</span>
                            }
                        </div>

                        <div class="d-flex align-items-center">
                            @if(Model.TieneRecetaFisica) {
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <span class="fw-bold text-dark fs-6 d-block">Receta Médica Adjunta</span>
                            } else {
                                <i class="bi bi-x-circle-fill text-danger fs-4 me-3"></i>
                                <span class="fw-semibold text-muted fs-6 text-decoration-line-through">Receta Médica</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
