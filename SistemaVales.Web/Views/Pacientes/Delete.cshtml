@model SistemaVales.Models.Paciente

@{
    ViewData["Title"] = "Eliminar Paciente";
}

<div class="card mb-5 mb-xl-10 border border-danger border-dashed">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1 text-danger"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> Eliminar Paciente</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Esta acción no se puede deshacer.</span>
        </h3>
    </div>
    <div class="card-body py-9 bg-light-danger">
        <div class="alert alert-dismissible bg-danger text-white d-flex flex-column flex-sm-row p-5 mb-10">
            <i class="bi bi-x-octagon-fill fs-2hx text-white me-4 mb-5 mb-sm-0"></i>
            <div class="d-flex flex-column pe-0 pe-sm-10">
                <h4 class="mb-2 text-white">Confirmación Requerida</h4>
                <span>¿Estás completamente seguro de que deseas eliminar permanentemente a <strong>@Model.Nombre</strong> (DNI: @Model.DNI)?</span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-light btn-active-light-primary me-2">Cancelar</a>
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Sí, Eliminar</button>
            </div>
        </form>
    </div>
</div>
