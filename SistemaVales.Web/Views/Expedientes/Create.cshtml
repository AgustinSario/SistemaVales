@model SistemaVales.Models.Expediente

@{
    ViewData["Title"] = "Crear Expediente";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 cursor-pointer pt-5">
        <div class="card-title m-0">
            <h3 class="fw-bold m-0"><i class="bi bi-folder-plus text-primary fs-2 me-2"></i> Apertura de Expediente</h3>
        </div>
    </div>
    
    <div class="card-body border-top p-9">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
            
            <div class="row mb-6">
                <label asp-for="NumeroExpediente" class="col-lg-3 col-form-label required fw-semibold fs-6">Número Expediente</label>
                <div class="col-lg-8">
                    <input asp-for="NumeroExpediente" class="form-control form-control-lg form-control-solid" placeholder="Ej: EXP-2026-001" />
                    <span asp-validation-for="NumeroExpediente" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6">
                <label asp-for="PacienteId" class="col-lg-3 col-form-label required fw-semibold fs-6">Paciente Solicitante</label>
                <div class="col-lg-8">
                    <select asp-for="PacienteId" class="form-select form-select-solid" data-control="select2" data-placeholder="Buscar paciente..." asp-items="ViewBag.Pacientes">
                        <option value="">-- Seleccione un Paciente --</option>
                    </select>
                    <span asp-validation-for="PacienteId" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6 mt-10">
                <label class="col-lg-3 col-form-label fw-semibold fs-6">Documentación Adjunta</label>
                <div class="col-lg-8">
                    <div class="d-flex align-items-center mb-4">
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input" type="checkbox" asp-for="InformeSocialEconomico" id="checkInforme" />
                            <label class="form-check-label fw-semibold text-gray-700 fs-6" for="checkInforme">
                                Informe Socio-Económico
                            </label>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center mb-4">
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input" type="checkbox" asp-for="HistoriaClinica" id="checkHC" />
                            <label class="form-check-label fw-semibold text-gray-700 fs-6" for="checkHC">
                                Historia Clínica Completa
                            </label>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="form-check form-check-custom form-check-solid">
                            <input class="form-check-input" type="checkbox" asp-for="Receta" id="checkReceta" />
                            <label class="form-check-label fw-semibold text-gray-700 fs-6" for="checkReceta">
                                Receta Médica Original
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-end py-6 px-9 bg-transparent border-0 mt-5">
                <a asp-action="Index" class="btn btn-light btn-active-light-primary me-2">Cancelar</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-file-earmark-plus me-1"></i> Iniciar Expediente</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            $('select#PacienteId').select2({
                placeholder: "-- Seleccione un Paciente --",
                allowClear: true,
                width: '100%',
                theme: "default"
            });
            // Estilizar el Select2 para que se vea como form-control-solid de Metronic
            $('.select2-container--default .select2-selection--single').css('background-color', '#f5f8fa');
            $('.select2-container--default .select2-selection--single').css('border-color', '#f5f8fa');
            $('.select2-container--default .select2-selection--single').css('height', 'calc(1.5em + 1.5rem + 2px)');
            $('.select2-container--default .select2-selection--single .select2-selection__rendered').css('line-height', 'calc(1.5em + 1.5rem + 2px)');
            $('.select2-container--default .select2-selection--single .select2-selection__arrow').css('height', 'calc(1.5em + 1.5rem + 2px)');
        });
    </script>
}
