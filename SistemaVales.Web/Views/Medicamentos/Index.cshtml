@model IEnumerable<SistemaVales.Models.Medicamento>

@{
    ViewData["Title"] = "Gestión de Medicamentos";
}

<div class="card mb-5 mb-xl-8">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Medicamentos Registrados</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Control de stock y asignaciones por paciente/hospital</span>
        </h3>
        <div class="card-toolbar">
            <a asp-action="Create" class="btn btn-sm btn-light-primary">
                <i class="bi bi-plus-lg me-2"></i> Nuevo Medicamento
            </a>
        </div>
    </div>
    <div class="card-body py-3">
        <div class="table-responsive">
            <table class="table align-middle gs-0 gy-4">
                <thead>
                    <tr class="fw-bold text-muted bg-light">
                        <th class="ps-4 min-w-200px rounded-start">Medicamento</th>
                        <th class="min-w-100px">Cantidad / Unidad</th>
                        <th class="min-w-150px">Descripción</th>
                        <th class="min-w-100px">Monto Est.</th>
                        <th class="min-w-120px text-end rounded-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="symbol symbol-45px me-5">
                                    <span class="symbol-label bg-light-primary">
                                        <i class="bi bi-capsule text-primary fs-2x"></i>
                                    </span>
                                </div>
                                <div class="d-flex justify-content-start flex-column">
                                    <span class="text-dark fw-bold fs-6">@item.Nombre</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="text-dark fw-bold d-block fs-6">@item.Cantidad</span>
                            <span class="text-muted fw-semibold d-block fs-7">@item.Unidad</span>
                        </td>
                        <td>
                            <span class="text-dark fw-bold d-block fs-6 text-truncate" style="max-width: 200px;" title="@item.Descripcion">@item.Descripcion</span>
                        </td>
                        <td>
                            <span class="text-dark fw-bold d-block fs-6">@item.MontoEstimado.ToString("C")</span>
                        </td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm me-1">
                                <i class="bi bi-pencil-fill fs-3"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-bg-light btn-active-color-primary btn-sm">
                                <i class="bi bi-trash-fill fs-3"></i>
                            </a>
                        </td>
                    </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
