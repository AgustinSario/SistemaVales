@model SistemaVales.Web.Models.DashboardViewModel

@{
    ViewData["Title"] = "Panel de Control";
}

<div class="row g-4 mb-5">
    <div class="col-12 mb-3">
        <h3 class="fw-bold text-dark mb-0">Resumen Operativo</h3>
        <span class="text-muted fw-semibold fs-7 d-block">Estadísticas en tiempo real del sistema</span>
    </div>

    <!-- Expedientes Creados -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid var(--bs-primary) !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Expedientes Totales</span>
                    <span class="fs-1 fw-bold text-dark">@Model.ExpedientesCreados</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #f1faff;">
                    <i class="bi bi-folder2-open fs-2" style="color: var(--bs-primary);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Expedientes En Compras -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid var(--bs-info) !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Expeds. en Compras</span>
                    <span class="fs-1 fw-bold text-dark">@Model.ExpedientesEnCompras</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #f8f5ff;">
                    <i class="bi bi-cart3 fs-2" style="color: var(--bs-info);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Vales Creados -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid var(--bs-warning) !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Vales Emitidos</span>
                    <span class="fs-1 fw-bold text-dark">@Model.ValesCreados</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #fff0f3;">
                    <i class="bi bi-receipt fs-2" style="color: var(--bs-warning);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Vales Entregados -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid var(--bs-success) !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Vales Finalizados</span>
                    <span class="fs-1 fw-bold text-dark">@Model.ValesEntregados</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #e8fff3;">
                    <i class="bi bi-check-circle fs-2" style="color: var(--bs-success);"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Recetas Creadas -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid #7239ea !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Recetas Totales</span>
                    <span class="fs-1 fw-bold text-dark">@Model.RecetasCreadas</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #f3f6fc;">
                    <i class="bi bi-file-medical fs-2" style="color: #7239ea;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Recetas Evaluadas -->
    <div class="col-sm-6 col-lg-4 mb-5">
        <div class="card shadow-sm border-0 h-100" style="border-bottom: 3px solid #50cd89 !important;">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold fs-7 d-block mb-1 text-uppercase">Recetas Auditadas</span>
                    <span class="fs-1 fw-bold text-dark">@Model.RecetasEvaluadas</span>
                </div>
                <div class="d-flex align-items-center justify-content-center rounded" style="width: 50px; height: 50px; background-color: #e8fff3;">
                    <i class="bi bi-clipboard-check fs-2" style="color: #50cd89;"></i>
                </div>
            </div>
        </div>
    </div>
</div>
