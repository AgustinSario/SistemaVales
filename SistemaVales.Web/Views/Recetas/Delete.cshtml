@model SistemaVales.Models.Receta

@{
    ViewData["Title"] = "Eliminar Receta";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 cursor-pointer pt-5">
        <div class="card-title m-0">
            <h3 class="fw-bold m-0 text-danger"><i class="bi bi-exclamation-triangle-fill text-danger fs-2 me-2"></i> Eliminar Receta</h3>
        </div>
    </div>
    
    <div class="card-body border-top p-9">
        <div class="alert alert-dismissible bg-light-danger d-flex flex-column flex-sm-row p-5 mb-10">
            <i class="bi bi-trash fs-2hx text-danger me-4 mb-5 mb-sm-0"></i>
            <div class="d-flex flex-column pe-0 pe-sm-10">
                <h4 class="mb-2 text-danger">Confirmación de Eliminación</h4>
                <span>¿Está seguro que desea eliminar la receta de <strong>@Model.Paciente?.Nombre</strong> (DNI: @Model.DNI)? Esta acción es permanente.</span>
            </div>
        </div>

        <div class="row mb-7">
            <label class="col-lg-4 fw-semibold text-muted">Hospital</label>
            <div class="col-lg-8">
                <span class="fw-bold fs-6 text-gray-800">@Model.Hospital?.Nombre</span>
            </div>
        </div>

        <div class="row mb-7">
            <label class="col-lg-4 fw-semibold text-muted">Obra Social</label>
            <div class="col-lg-8">
                <span class="badge @(Model.TieneObraSocial ? "badge-light-success" : "badge-light-danger")">
                    @(Model.TieneObraSocial ? "Tiene Obra Social" : "No Tiene Obra Social")
                </span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="card-footer d-flex justify-content-end py-6 px-9 bg-transparent border-0 mt-5">
                <a asp-action="Index" class="btn btn-light btn-active-light-primary me-2">Cancelar</a>
                <button type="submit" class="btn btn-danger">Eliminar Definitivamente</button>
            </div>
        </form>
    </div>
</div>
