@model SistemaVales.Models.Vale
@{
    ViewData["Title"] = "Detalle del Vale";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 cursor-pointer pt-5">
        <div class="card-title m-0">
            <h3 class="fw-bold m-0"><i class="bi bi-info-circle text-primary fs-2 me-2"></i> Detalle de Vale #@Model.NumeroVale</h3>
        </div>
    </div>
    
    <div class="card-body p-9">
        <div class="row g-5">
            <!-- Info Voucher -->
            <div class="col-lg-8">
                <div class="card bg-light-primary border-0 p-5 mb-5">
                    <h4 class="fw-bold text-primary mb-5">Datos del Vale</h4>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Número de Vale:</div>
                        <div class="col-sm-8 text-gray-600">@Model.NumeroVale</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Fecha de Emisión:</div>
                        <div class="col-sm-8 text-gray-600">@Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Paciente:</div>
                        <div class="col-sm-8 text-gray-600">@Model.Expediente?.Paciente?.Nombre (DNI: @Model.Expediente?.Paciente?.DNI)</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Hospital:</div>
                        <div class="col-sm-8 text-gray-600">@Model.Expediente?.Paciente?.Hospital?.Nombre</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Medicamento:</div>
                        <div class="col-sm-8 text-gray-600">@Model.Medicamento?.Nombre</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Monto:</div>
                        <div class="col-sm-8 text-gray-600 fw-bold fs-4 text-dark">$@Model.Monto</div>
                    </div>
                    <div class="row mb-5">
                        <div class="col-sm-4 fw-semibold text-gray-800">Estado:</div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.Estado == "Iniciado" ? "badge-light-warning" : Model.Estado == "Proceso" ? "badge-light-info" : "badge-light-success") px-4 py-3">
                                @Model.Estado
                            </span>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.EntregadoPor))
                    {
                        <div class="row mb-5">
                            <div class="col-sm-4 fw-semibold text-gray-800">Entregado Por:</div>
                            <div class="col-sm-8 text-danger fw-bold">@Model.EntregadoPor</div>
                        </div>
                    }
                </div>
            </div>

            <!-- QR Code -->
            <div class="col-lg-4 text-center">
                <div class="card border-dashed border-primary p-5">
                    <h5 class="fw-bold mb-5">Código QR de Seguridad</h5>
                    @if (ViewBag.QRCodeImage != null)
                    {
                        <img src="data:image/png;base64,@ViewBag.QRCodeImage" alt="QR Code" class="img-fluid mx-auto mb-5" style="max-width: 250px;" />
                        <div class="text-muted small">
                            Escanee este código para validar la autenticidad del vale y verificar los datos del paciente.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-footer d-flex justify-content-end py-6 px-9 bg-transparent">
        <button onclick="window.print()" class="btn btn-primary me-2"><i class="bi bi-printer me-1"></i> Imprimir Vale</button>
        <a asp-action="Index" class="btn btn-light btn-active-light-primary">Volver al Listado</a>
    </div>
</div>

<style>
    @@media print {
        .btn, header, footer, nav, .card-footer {
            display: none !important;
        }
        .card {
            border: none !important;
            box-shadow: none !important;
        }
        .container {
            width: 100% !important;
            max-width: 100% !important;
        }
    }
</style>
