@model SistemaVales.Models.Medicamento

@{
    ViewData["Title"] = "Editar Medicamento";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 cursor-pointer pt-5">
        <div class="card-title m-0">
            <h3 class="fw-bold m-0"><i class="bi bi-pencil-square text-primary fs-2 me-2"></i> Editar Medicamento</h3>
        </div>
    </div>
    
    <div class="card-body border-top p-9">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="row mb-6">
                <label asp-for="Nombre" class="col-lg-4 col-form-label required fw-semibold fs-6">Nombre del Medicamento</label>
                <div class="col-lg-8">
                    <input asp-for="Nombre" class="form-control form-control-lg form-control-solid" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6">
                <label asp-for="Cantidad" class="col-lg-4 col-form-label required fw-semibold fs-6">Cantidad</label>
                <div class="col-lg-8">
                    <input asp-for="Cantidad" class="form-control form-control-lg form-control-solid" />
                    <span asp-validation-for="Cantidad" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6">
                <label asp-for="Unidad" class="col-lg-4 col-form-label required fw-semibold fs-6">Unidad</label>
                <div class="col-lg-8">
                    <input asp-for="Unidad" class="form-control form-control-lg form-control-solid" />
                    <span asp-validation-for="Unidad" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6">
                <label asp-for="Descripcion" class="col-lg-4 col-form-label required fw-semibold fs-6">Descripción / Presentación</label>
                <div class="col-lg-8">
                    <textarea asp-for="Descripcion" class="form-control form-control-lg form-control-solid" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>
            </div>

            <div class="row mb-6">
                <label asp-for="MontoEstimado" class="col-lg-4 col-form-label required fw-semibold fs-6">Monto Estimado ($)</label>
                <div class="col-lg-8">
                    <input asp-for="MontoEstimado" class="form-control form-control-lg form-control-solid" type="number" step="0.01" />
                    <span asp-validation-for="MontoEstimado" class="text-danger"></span>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-end py-6 px-9 bg-transparent border-0 mt-5">
                <a asp-action="Index" class="btn btn-light btn-active-light-primary me-2">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
