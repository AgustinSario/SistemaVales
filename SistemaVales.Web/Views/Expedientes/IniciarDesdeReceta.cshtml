@model SistemaVales.Models.Expediente

@{
    var receta = ViewBag.Receta as SistemaVales.Models.Receta;
    ViewData["Title"] = "Mesa de Entrada - Iniciar Expediente";
}

<div class="card mb-5 mb-xl-10">
    <div class="card-header border-0 pt-5">
        <h3 class="card-title align-items-start flex-column">
            <span class="card-label fw-bold fs-3 mb-1">Iniciar Expediente desde Receta</span>
            <span class="text-muted mt-1 fw-semibold fs-7">Mesa de Entrada - Registro inicial del expediente</span>
        </h3>
    </div>
    
    <div class="card-body border-top p-9">
        <div class="alert alert-dismissible bg-light-primary d-flex flex-column flex-sm-row p-5 mb-10">
            <i class="bi bi-info-circle fs-2hx text-primary me-4 mb-5 mb-sm-0"></i>
            <div class="d-flex flex-column pe-0 pe-sm-10">
                <h4 class="mb-2 text-primary">Información de la Receta</h4>
                <span>Paciente: <strong>@receta?.Paciente?.Nombre</strong> | DNI: <strong>@receta?.DNI</strong> | Monto: <strong>@receta?.MontoTotal.ToString("C")</strong></span>
            </div>
        </div>

        <form asp-action="IniciarDesdeReceta">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
            <input type="hidden" name="recetaId" value="@receta?.Id" />
            
            <div class="row mb-6">
                <label class="col-lg-4 col-form-label required fw-semibold fs-6">Número de Expediente</label>
                <div class="col-lg-8">
                    <input name="numeroExpediente" class="form-control form-control-lg form-control-solid" placeholder="Ej: EXP-2024-001" required />
                    <div class="form-text">Ingrese el número de expediente físico registrado en mesa de entrada.</div>
                </div>
            </div>

            <div class="card-footer d-flex justify-content-end py-6 px-9 bg-transparent border-0 mt-5">
                <a asp-controller="Recetas" asp-action="Index" class="btn btn-light btn-active-light-primary me-2">Volver</a>
                <button type="submit" class="btn btn-primary">Iniciar y Continuar Flujo</button>
            </div>
        </form>
    </div>
</div>
