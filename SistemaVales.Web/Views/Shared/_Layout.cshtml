<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemaVales</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4">
            <div class="container-fluid px-5">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="fw-bold">SistemaVales</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4 gap-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i> Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Pacientes" asp-action="Index"><i class="bi bi-people me-1"></i> Pacientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Hospitales" asp-action="Index"><i class="bi bi-hospital me-1"></i> Hospitales</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Recetas" asp-action="Index"><i class="bi bi-file-earmark-medical me-1"></i> Recetas</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Farmacia" asp-action="Index"><i class="bi bi-capsule-pill me-1 text-success"></i> Farmacia</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Expedientes" asp-action="Index"><i class="bi bi-folder2-open me-1"></i> Expedientes</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Vales" asp-action="Index"><i class="bi bi-receipt me-1"></i> Vales</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Medicamentos" asp-action="Index"><i class="bi bi-capsule me-1"></i> Medicamentos</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="text-muted small me-2"><i class="bi bi-person-circle"></i> @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        <i class="bi bi-box-arrow-right"></i> Salir
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm rounded-pill px-4" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-lock"></i> Ingresar
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container-fluid px-5 mt-5 flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-center mt-auto py-4" style="position: relative !important; bottom: auto !important;">
        <div class="container">
            Dirección de Sistemas | Ministerio de Salud | R.C.K SRL
        </div>
    </footer>

    <!-- Chatbot Widget -->
    <div id="chatbot-container" class="chatbot-closed">
        <button id="chatbot-toggle" class="btn btn-primary btn-icon rounded-circle shadow-lg" aria-label="Abrir Chatbot">
            <i class="bi bi-chat-dots-fill fs-2"></i>
        </button>

        <div id="chatbot-window" class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white p-4 rounded-top d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                        <i class="bi bi-robot text-primary fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 text-white fw-bold">Asistente Virtual</h5>
                        <small class="text-white-50">Consulta de Expedientes</small>
                    </div>
                </div>
                <button id="chatbot-close" class="btn btn-sm btn-icon btn-color-white btn-active-color-light">
                    <i class="bi bi-x-lg fs-4"></i>
                </button>
            </div>
            
            <div id="chatbot-messages" class="card-body p-4" style="height: 350px; overflow-y: auto; background-color: #f5f8fa;">
                <!-- Initial Message -->
                <div class="d-flex flex-column mb-5 align-items-start">
                    <div class="d-flex align-items-center mb-1 gap-2">
                        <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 25px; height: 25px;">
                            <i class="bi bi-robot text-white fs-7"></i>
                        </div>
                        <span class="text-muted fs-7 fw-bold">Asistente</span>
                    </div>
                    <div class="p-3 rounded bg-white text-dark shadow-sm border border-gray-200" style="max-width: 85%; border-top-left-radius: 0 !important;">
                        ¡Hola! Soy tu asistente virtual. Por favor, <strong>ingresa el número de expediente</strong> que deseas consultar (Ej: 310-2020-2026).
                    </div>
                </div>
            </div>

            <div class="card-footer p-3 bg-white border-top">
                <form id="chatbot-form" class="position-relative">
                    <input type="text" id="chatbot-input" class="form-control form-control-solid rounded px-4 py-3 pe-10" placeholder="Escribe el expediente..." autocomplete="off">
                    <button type="submit" class="btn btn-icon btn-sm btn-primary position-absolute top-50 end-0 translate-middle-y me-2 rounded-circle" id="chatbot-send">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
